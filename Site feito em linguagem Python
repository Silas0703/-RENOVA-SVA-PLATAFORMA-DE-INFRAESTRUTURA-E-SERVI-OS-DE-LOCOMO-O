"""
Renova SVA - Backend API
Plataforma de Infraestrutura e Serviços de Locomoção
Desenvolvido em Python com FastAPI
"""

from fastapi import FastAPI, HTTPException
from pydantic import BaseModel
from typing import List, Optional
from datetime import datetime

# ======================
# Configurações da API
# ======================

app = FastAPI(
    title="Renova SVA API",
    description="Backend para gestão de locomoção sustentável",
    version="1.0.0",
    docs_url="/docs",
    redoc_url="/redoc"
)

# ======================
# Modelos de Dados
# ======================

class Veiculo(BaseModel):
    id: int
    nome: str
    tipo: str
    modelo: str
    autonomia: float
    preco_por_hora: float
    preco_por_km: float
    disponivel: bool
    imagem_url: Optional[str] = None
    categoria: str  # Premium, Padrão, Básico

class Locacao(BaseModel):
    id: int
    veiculo_id: int
    usuario_id: int
    data_inicio: datetime
    data_fim: Optional[datetime] = None
    km_inicial: float
    km_final: Optional[float] = None
    status: str  # ativa, finalizada, cancelada
    valor_total: Optional[float] = None

class Usuario(BaseModel):
    id: int
    nome: str
    email: str
    cpf: str
    telefone: str
    tipo_usuario: str  # cliente, admin
    ativo: bool = True

class Estacao(BaseModel):
    id: int
    nome: str
    endereco: str
    latitude: float
    longitude: float
    capacidade: int
    vagas_disponiveis: int
    tipo_carregador: str  # rápido, normal

