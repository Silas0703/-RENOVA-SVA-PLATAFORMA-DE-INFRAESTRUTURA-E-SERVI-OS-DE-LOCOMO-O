# ======================
# Endpoints - Estatísticas
# ======================

@app.get("/api/dashboard")
async def get_dashboard():
    """Retorna dados para dashboard"""
    total_veiculos = len(db_veiculos)
    veiculos_disponiveis = len([v for v in db_veiculos if v.disponivel])
    veiculos_locados = total_veiculos - veiculos_disponiveis
    locacoes_ativas = len([l for l in db_locacoes if l.status == "ativa"])
    
    return {
        "total_veiculos": total_veiculos,
        "veiculos_disponiveis": veiculos_disponiveis,
        "veiculos_locados": veiculos_locados,
        "locacoes_ativas": locacoes_ativas,
        "total_estacoes": len(db_estacoes)
    }

