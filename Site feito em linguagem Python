@app.get("/api/veiculos", response_model=List[Veiculo])
async def listar_veiculos(disponivel_only: bool = False):
    """Retorna lista de veículos"""
    if disponivel_only:
        return [v for v in db_veiculos if v.disponivel]
    return db_veiculos

@app.get("/api/veiculos/{veiculo_id}", response_model=Veiculo)
async def get_veiculo(veiculo_id: int):
    """Retorna um veículo específico"""
    for veiculo in db_veiculos:
        if veiculo.id == veiculo_id:
            return veiculo
    raise HTTPException(status_code=404, detail="Veículo não encontrado")

@app.post("/api/veiculos")
async def criar_veiculo(veiculo: Veiculo):
    """Cria um novo veículo"""
    veiculo.id = len(db_veiculos) + 1
    db_veiculos.append(veiculo)
    return {"sucesso": True, "veiculo": veiculo}

