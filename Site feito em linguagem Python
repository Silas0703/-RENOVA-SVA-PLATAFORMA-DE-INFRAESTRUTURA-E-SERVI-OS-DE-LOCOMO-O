@app.get("/api/locacoes", response_model=List[Locacao])
async def listar_locacoes(usuario_id: int = None):
    """Retorna lista de locações"""
    if usuario_id:
        return [l for l in db_locacoes if l.usuario_id == usuario_id]
    return db_locacoes

@app.post("/api/locacoes")
async def criar_locacao(veiculo_id: int, usuario_id: int, km_inicial: float):
    """Cria uma nova locação"""
    # Verifica se veículo existe e está disponível
    veiculo_encontrado = None
    for v in db_veiculos:
        if v.id == veiculo_id:
            veiculo_encontrado = v
            break
    
    if not veiculo_encontrado:
        raise HTTPException(status_code=404, detail="Veículo não encontrado")
    
    if not veiculo_encontrado.disponivel:
        raise HTTPException(status_code=400, detail="Veículo indisponível")
    
    # Cria locação
    locacao = Locacao(
        id=len(db_locacoes) + 1,
        veiculo_id=veiculo_id,
        usuario_id=usuario_id,
        data_inicio=datetime.now(),
        km_inicial=km_inicial,
        status="ativa"
    )
    
    # Marca veículo como indisponível
    veiculo_encontrado.disponivel = False
    db_locacoes.append(locacao)
    
    return {
        "sucesso": True,
        "mensagem": f"Veículo {veiculo_encontrado.nome} locado com sucesso!",
        "locacao": locacao
    }

@app.put("/api/locacoes/{locacao_id}/devolver")
async def devolver_veiculo(locacao_id: int, km_final: float):
    """Finaliza uma locação"""
    for locacao in db_locacoes:
        if locacao.id == locacao_id:
            if locacao.status != "ativa":
                raise HTTPException(status_code=400, detail="Locação já finalizada")
            
            # Calcula valor total
            km_percorridos = km_final - locacao.km_inicial
            
            # Busca veículo para get preco
            veiculo = None
            for v in db_veiculos:
                if v.id == locacao.veiculo_id:
                    veiculo = v
                    break
            
            if veiculo:
                # Calcula por hora (mínimo 1 hora) e por km
                tempo_horas = max(1, (datetime.now() - locacao.data_inicio).seconds / 3600)
                valor = (tempo_horas * veiculo.preco_por_hora) + (km_percorridos * veiculo.preco_por_km)
                
                locacao.data_fim = datetime.now()
                locacao.km_final = km_final
                locacao.status = "finalizada"
                locacao.valor_total = valor
                
                # Libera veículo
                veiculo.disponivel = True
                
                return {
                    "sucesso": True,
                    "mensagem": "Veículo devolvido com sucesso!",
                    "km_percorridos": km_percorridos,
                    "tempo_horas": tempo_horas,
                    "valor_total": round(valor, 2)
                }
    
    raise HTTPException(status_code=404, detail="Locação não encontrada")

